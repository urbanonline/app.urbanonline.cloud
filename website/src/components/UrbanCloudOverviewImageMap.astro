---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  src: ImageMetadata;
  alt: string;
  title?: string;
  caption?: string;
  captionPrefix?: string;
  languagePrefix?: string; 
  labels: {
    network: string;
    registration: string;
    rest: string;
    sync: string;
    networkIcon: string;
    registrationIcon: string;
    restIcon: string;
    syncIcon: string;
  };
}

const { src, alt, title, languagePrefix = "", labels } = Astro.props;
const areas = [
  { href: `${languagePrefix}/guide/service/setup-cloud/network`,      left: "16%", top: "30%", width: "60%", height: "9%", label: labels.network },
  { href: `${languagePrefix}/guide/service/setup-cloud/network#view-connectivity-details`,      left: "76.5%", top: "29%", width: "7%", height: "11%", label: labels.networkIcon},

  { href: `${languagePrefix}/guide/service/setup-cloud/registration`, left: "16%", top: "44%", width: "60%", height: "9%", label: labels.registration },
  { href: `${languagePrefix}/guide/service/setup-cloud/registration#registration-terminal`,      left: "76.5%", top: "43%", width: "7%", height: "11%", label: labels.registrationIcon},

  { href: `${languagePrefix}/guide/service/setup-cloud/rest`,         left: "16%", top: "57%", width: "60%", height: "9%", label: labels.rest },
  { href: `${languagePrefix}/guide/service/setup-cloud/rest#activate-rest-api`,      left: "76.5%", top: "56%", width: "7%", height: "11%", label: labels.restIcon},

  { href: `${languagePrefix}/guide/service/setup-cloud/sync`,         left: "16%", top: "71%", width: "60%", height: "9%", label: labels.sync },
  { href: `${languagePrefix}/guide/service/setup-cloud/sync#installation-sync-service`,      left: "76.5%", top: "70%", width: "7%", height: "11%", label: labels.syncIcon},
];
---
<Image src={src} alt={alt} title={title} />
{areas.map((area) => (
  <a
    href={area.href}
    aria-label={area.label}
    title={area.label}
    class:list={[
      "absolute transition-colors",
      "border-2 border-transparent",
      "hover:border-red-500 hover:bg-blue-400/20",
    ]}
    style={{ left: area.left, top: area.top, width: area.width, height: area.height }}
  />
))}
