---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  src: ImageMetadata;
  alt: string;
  caption?: string;
  captionPrefix?: string;
  languagePrefix?: string; 
  labels: {
    network: string;
    registration: string;
    rest: string;
    sync: string;
    networkIcon: string;
    registrationIcon: string;
    restIcon: string;
    syncIcon: string;
  };
  anchors: {
    networkIconAnchor: string;
    registrationIconAnchor: string;
    restIconAnchor: string;
    syncIconAnchor: string;
  }
}

const { src, alt, caption, captionPrefix, languagePrefix = "", labels, anchors } = Astro.props;

const areas = [
  { href: `${languagePrefix}/guide/service/setup-cloud/network`,                                        left: "13%", top: "17.8%", width: "65%", height: "11%", label: labels.network },
  { href: `${languagePrefix}/guide/service/setup-cloud/network#${anchors.networkIconAnchor}`,           left: "81.9%", top: "17.8%", width: "5.3%", height: "11%", label: labels.networkIcon},

  { href: `${languagePrefix}/guide/service/setup-cloud/registration`,                                   left: "13%", top: "31.1%", width: "65%", height: "11%", label: labels.registration },
  { href: `${languagePrefix}/guide/service/setup-cloud/registration#${anchors.registrationIconAnchor}`,  left: "81.9%", top: "31.1%", width: "5.3%", height: "11%", label: labels.registrationIcon},

  { href: `${languagePrefix}/guide/service/setup-cloud/rest`,                                           left: "13%", top: "44.4%", width: "65%", height: "11%", label: labels.rest },
  { href: `${languagePrefix}/guide/service/setup-cloud/rest#${anchors.restIconAnchor}`,                  left: "81.9%", top: "44.4%", width: "5.3%", height: "11%", label: labels.restIcon},

  { href: `${languagePrefix}/guide/service/setup-cloud/sync`,                                           left: "13%", top: "57.7%", width: "65%", height: "11%", label: labels.sync },
  { href: `${languagePrefix}/guide/service/setup-cloud/sync#${anchors.syncIconAnchor}`,                  left: "81.9%", top: "57.7%", width: "5.3%", height: "11%", label: labels.syncIcon},
];
---

<figure>
  <div class="border border-gray-300 rounded-xs p-4">
    <div class="relative inline-block">
      <Image src={src} alt={alt} />

      {areas.map((area) => (
        <a
          href={area.href}
          aria-label={area.label}
          title={area.label}
          class:list={[
            "absolute transition-colors",
            "border-2 border-transparent",
            "hover:border-red-500 hover:bg-blue-400/20",
          ]}
          style={{ left: area.left, top: area.top, width: area.width, height: area.height }}
        />
      ))}
    </div>
  </div>
  {caption && (
    <figcaption class="text-sm mt-2">
      {captionPrefix && <span>{captionPrefix}</span>} {caption}
    </figcaption>
  )}
</figure>
