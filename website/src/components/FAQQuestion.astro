---
export interface FaqItem {
  question: string;
  answer: string;
  id?: string;
}

interface Props {
  items: FaqItem[];
  groupName?: string;
}

const {
  items,
  groupName = "faq-group",
} = Astro.props;

function slugify(text: string): string {
  return text
    .toLowerCase()
    .normalize("NFKD")
    .replace(/[\u0300-\u036f]/g, "")
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/(^-|-$)/g, "");
}
---

<div class="faq-wrapper max-w-xl mx-auto flex flex-col items-center px-4 md:px-0">

  <div class="faq-container w-full">
    {items.map((faq) => {
      const anchorId = faq.id ?? slugify(faq.question);
      return (
        <details id={anchorId} name={groupName} class="faq-item group border-b border-slate-200 py-4 w-full">
          <summary class="faq-summary flex items-center justify-between gap-4 cursor-pointer w-full">
            <h3 class="text-base font-medium">{faq.question}</h3>
            <svg
              width="18"
              height="18"
              viewBox="0 0 18 18"
              fill="none"
              xmlns="http://www.w3.org/2000/svg"
              class="faq-icon shrink-0 transition-transform duration-500 ease-in-out group-open:rotate-180"
            >
              <path
                d="m4.5 7.2 3.793 3.793a1 1 0 0 0 1.414 0L13.5 7.2"
                stroke="#1D293D"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"
              ></path>
            </svg>
          </summary>

          <div class="faq-answer text-sm text-slate-500 max-w-md pt-4" set:html={faq.answer} />
        </details>
      );
    })}
  </div>
</div>

<style>
  details.faq-item {
    border-left: none !important;
    padding-left: 0 !important;
    margin-left: 0 !important;
    background: none !important;
  }

  details.faq-item > summary.faq-summary {
    list-style: none !important;
  }
  details.faq-item > summary.faq-summary::-webkit-details-marker {
    display: none !important;
  }
  details.faq-item > summary.faq-summary::marker {
    content: "" !important;
    display: none !important;
  }

  details.faq-item > summary.faq-summary::before,
  details.faq-item > summary.faq-summary::after {
    content: none !important;
    display: none !important;
  }

  .faq-answer :global(strong) {
    font-weight: 600;
    color: inherit;
  }
  .faq-answer :global(a) {
    color: #4f46e5; /* indigo-600 */
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .faq-answer :global(.faq-highlight) {
    color: #4f46e5;
    font-weight: 600;
  }

  /* Sanfter Farbwechsel beim Hover über die Frage. */
  .faq-summary:hover h3 {
    color: #4f46e5;
  }
  .faq-summary h3 {
    transition: color 200ms ease;
  }
</style>