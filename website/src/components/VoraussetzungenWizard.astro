---
// VoraussetzungenWizard.astro
// Einbindung im MDX:
// import VoraussetzungenWizard from '../../../../components/VoraussetzungenWizard.astro';
// <VoraussetzungenWizard />
---

<div style="padding: 1.5rem 0;" id="vw-wizard">
  <div id="vw-progress" aria-hidden="true" style="display: flex; align-items: center; gap: 6px; margin-bottom: 2rem;"></div>
  <div id="vw-content"></div>
</div>

<script>
(function () {
  interface NeinAction {
    title: string;
    action: string;
  }

  interface Step {
    id: string;
    label: string;
    title: string;
    question: string;
    hint: string | null;
    nein: NeinAction | null;
  }

  // Reihenfolge der IDs für den normalen Pfad
  const steps: Step[] = [
    {
      id: 'smartphone',
      label: 'Checkpoint 1',
      title: 'Smartphone',
      question: 'Ist ein iPhone oder Android-Gerät vorhanden?',
      hint: null,
      nein: {
        title: 'Kein Smartphone vorhanden',
        action: 'Die Urban Feed Monitor App erfordert ein iPhone (iOS) oder ein Android-Gerät.',
      },
    },
    {
      id: 'appstore',
      label: 'Checkpoint 2',
      title: 'App installiert',
      question: 'Ist die Urban Feed Monitor App bereits auf Ihrem Gerät installiert?',
      hint: null,
      nein: {
        title: 'App noch nicht installiert',
        action: 'Laden Sie die Urban Feed Monitor App herunter: <a href="https://apps.apple.com/de/app/urban-feed-monitor/id6746261090" target="_blank" rel="noopener">App Store (iOS)</a> oder <a href="https://play.google.com/store/apps/details?id=com.app.urban_alma_pro" target="_blank" rel="noopener">Google Play (Android)</a>',
      },
    },
    {
      id: 'alma',
      label: 'Checkpoint 3',
      title: 'Automat',
      question: 'Ist ein Alma Pro Fütterungsautomat vorhanden?',
      hint: 'Vorgängermodelle sind nicht kompatibel. <a href="/prerequisites/feeder/model">Ermittlung des Modells</a>',
      nein: {
        title: 'Kein Alma Pro Fütterungsautomat vorhanden',
        action: '',  // wird in renderSummary gesondert behandelt
      },
    },
    {
      id: 'terminal',
      label: 'Checkpoint 4',
      title: 'TouchTerminal',
      question: 'Ist ein TouchTerminal der 2. Generation vorhanden?',
      hint: 'Terminals der 2. Generation wurden ab 2020 ausgeliefert. <a href="/prerequisites/feeder/terminal">Ermittlung der Generation</a>',
      nein: {
        title: 'TouchTerminal Gen 2 fehlt',
        action: 'Wenden Sie sich an Ihren Urban-Servicepartner für einen Austausch Ihres inkompatiblen Terminalmodells.',
      },
    },
    {
      id: 'firmware',
      label: 'Checkpoint 5',
      title: 'Firmware',
      question: 'Ist Firmwareversion 25-04-V08 oder höher auf der Alma Pro installiert?',
      hint: 'Prüfung am Gerät: Home-Schaltfläche → Hilfe-Symbol (oben rechts). Die Versionsnummer erscheint links neben der Sprachumschaltung. <a href="/prerequisites/feeder/firmware">Detaillierte Anleitung</a>',
      nein: {
        title: 'Firmware veraltet',
        action: 'Vereinbaren Sie einen Servicetermin für das Firmware-Update. Fahren Sie in der Zwischenzeit mit den Schritten 1–3 fort (Registrierung, Einloggen, Stall anlegen), damit beim Servicetermin sofort das Terminal hinzugefügt werden kann. Starten Sie jetzt mit <a href="/guide/user/01-registrierung" style="color: #27500A; font-weight: 600;">Schritt 1: Registrierung</a>.',
      },
    },
    {
      id: 'internet',
      label: 'Checkpoint 6',
      title: 'Internetverbindung im Stall',
      question: 'Ist im Stall eine Internetverbindung vorhanden (d.h. es besteht eine Verbindung nach außen, nicht nur ein lokales Netzwerk)?',
      hint: '<a href="/prerequisites/feeder/network">Nähere Hinweise zum Netzwerk</a>',
      nein: {
        title: 'Keine Internetverbindung im Stall',
        action: 'Eine Internetverbindung im Stall ist Voraussetzung für die Urban Cloud. Klären Sie dies mit Ihrem Netzwerktechniker – Urban kann hierbei nicht unterstützen.',
      },
    },
    {
      id: 'router',
      label: 'Checkpoint 7',
      title: 'Urban Router',
      question: 'Ist ein Urban Router im Stall installiert?',
      hint: null,
      nein: {
        title: 'Kein Urban Router vorhanden',
        action: '',  // wird in renderSummary kontextabhängig gesetzt
      },
    },
  ];

  // Welche Step-IDs werden bei alma=nein übersprungen
  const SKIP_IF_NO_ALMA = new Set(['terminal', 'firmware', 'router']);

  const total = steps.length;
  let current = 0;
  const answers: Record<string, boolean> = {};

  const progressEl = document.getElementById('vw-progress') as HTMLElement;
  const contentEl = document.getElementById('vw-content') as HTMLElement;

  const cs = getComputedStyle(document.documentElement);
  const C = {
    bg:        cs.getPropertyValue('--sl-color-bg').trim()         || '#ffffff',
    bgSidebar: cs.getPropertyValue('--sl-color-bg-sidebar').trim() || '#f5f5f5',
    border:    cs.getPropertyValue('--sl-color-gray-5').trim()     || '#d1d5db',
    borderSub: cs.getPropertyValue('--sl-color-gray-6').trim()     || '#e5e7eb',
    text:      cs.getPropertyValue('--sl-color-text').trim()       || '#111827',
    gray2:     cs.getPropertyValue('--sl-color-gray-2').trim()     || '#6b7280',
    gray3:     cs.getPropertyValue('--sl-color-gray-3').trim()     || '#9ca3af',
    gray4:     cs.getPropertyValue('--sl-color-gray-4').trim()     || '#d1d5db',
  };

  function visibleIndex(idx: number): number {
    let skipped = 0;
    if (answers['smartphone'] === false)
      skipped += steps.slice(0, idx).filter(s => s.id === 'appstore').length;
    if (answers['alma'] === false)
      skipped += steps.slice(0, idx).filter(s => SKIP_IF_NO_ALMA.has(s.id)).length;
    else if (answers['internet'] === false)
      skipped += steps.slice(0, idx).filter(s => s.id === 'router').length;
    return idx - skipped;
  }

  function visibleTotal(): number {
    let skip = 0;
    if (answers['smartphone'] === false) skip += 1;
    if (answers['alma'] === false) skip += SKIP_IF_NO_ALMA.size;
    else if (answers['internet'] === false) skip += 1;
    return total - skip;
  }

  function renderProgress(activeIdx: number, allDone: boolean): void {
    const vTotal = visibleTotal();
    const vActive = visibleIndex(activeIdx);
    progressEl.innerHTML = Array.from({ length: vTotal }, (_, i) => {
      let bg = C.border;
      if (allDone || i < vActive) bg = '#0F9DD8';
      else if (i === vActive) bg = '#810012';
      return `<div style="flex: 1; height: 4px; border-radius: 2px; background: ${bg}; transition: background 0.3s; margin-top: 0;"></div>`;
    }).join('');
  }

  function renderStep(): void {
    const s = steps[current];
    const vIdx = visibleIndex(current);
    const vTot = visibleTotal();
    renderProgress(current, false);

    const hintHtml = s.hint
      ? `<div style="font-size: 0.8125rem; color: ${C.gray2}; background: ${C.bgSidebar}; border-radius: 0.5rem; padding: 0.75rem 1rem; margin-bottom: 1.25rem; line-height: 1.6;">${s.hint}</div>`
      : '';

    contentEl.innerHTML = `
      <div style="background: ${C.bg}; border: 1px solid ${C.border}; border-radius: 0.75rem; padding: 1.25rem 1.5rem; margin-bottom: 1rem;">
        <div style="font-size: 0.75rem; color: ${C.gray3}; margin-bottom: 0.25rem; text-transform: uppercase; letter-spacing: 0.05em;">Checkpoint ${vIdx + 1} von ${vTot}</div>
        <div style="font-size: 1.25rem; font-weight: 600; color: ${C.text}; margin-bottom: 0.75rem; border-bottom: 1px solid ${C.borderSub}; padding-bottom: 0.5rem;">${s.title}</div>
        <div style="font-size: 0.9375rem; color: ${C.text}; line-height: 1.6; margin-bottom: 1.25rem;">${s.question}</div>
        ${hintHtml}
        <div style="display: flex; gap: 10px;">
          <button data-answer="true" style="margin: 0; flex: 1; box-sizing: border-box; height: 2.75rem; padding: 0 1rem; border-radius: 0.5rem; border: 1px solid #3B6D11; background: ${C.bg}; color: #3B6D11; font-size: 0.9375rem; cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 8px;"><span class="text-2xl">✓</span> Ja</button>
          <button data-answer="false" style="margin: 0; flex: 1; box-sizing: border-box; height: 2.75rem; padding: 0 1rem; border-radius: 0.5rem; border: 1px solid #A32D2D; background: ${C.bg}; color: #A32D2D; font-size: 0.9375rem; cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 8px;"><span class="text-2xl">✕</span> Nein</button>
        </div>
      </div>`;

    contentEl.querySelectorAll('button[data-answer]').forEach((btn) => {
      const el = btn as HTMLButtonElement;
      el.addEventListener('click', () => answer(el.dataset['answer'] === 'true'));
    });
  }

  function answer(ja: boolean): void {
    const s = steps[current];
    answers[s.id] = ja;

    // Nächsten Schritt ermitteln – ggf. überspringen
    let next = current + 1;
    while (next < total) {
      const nextId = steps[next].id;
      if (answers['smartphone'] === false && nextId === 'appstore') { next++; continue; }
      if (answers['alma'] === false && SKIP_IF_NO_ALMA.has(nextId)) { next++; continue; }
      if (answers['internet'] === false && nextId === 'router') { next++; continue; }
      break;
    }
    current = next;

    if (current < total) { renderStep(); } else { renderSummary(); }
  }

  function summaryItem(title: string, body: string): string {
    return `<div style="border: 1px solid #F09595; border-left: 3px solid #A32D2D; background: #FCEBEB; border-radius: 0.5rem; padding: 0.9rem 1rem; margin-bottom: 0.75rem;">
      <div style="font-weight: 700; font-size: 0.9375rem; color: #A32D2D; margin-bottom: 0.4rem;">${title}</div>
      <div style="font-size: 0.8125rem; color: #501313; line-height: 1.6;">${body}</div>
    </div>`;
  }

  function renderSummary(): void {
    renderProgress(total, true);

    const neinSmartphone = answers['smartphone'] === false;
    const neinAppstore   = answers['appstore']   === false;
    const neinAlma       = answers['alma']        === false;
    const neinTerminal   = answers['terminal']    === false;
    const neinFirmware   = answers['firmware']    === false;
    const neinInternet   = answers['internet']    === false;
    const neinRouter     = answers['router']      === false;

    const items: string[] = [];

    if (neinSmartphone) {
      items.push(summaryItem('⚠ Kein Smartphone vorhanden',
        'Die Urban Feed Monitor App erfordert ein iPhone (iOS) oder ein Android-Gerät.'));
    }

    if (neinAppstore && !neinSmartphone) {
      items.push(`<div style="border: 1px solid #F09595; border-left: 3px solid #A32D2D; background: #FCEBEB; border-radius: 0.5rem; padding: 0.9rem 1rem; margin-bottom: 0.75rem;">
        <div style="font-weight: 700; font-size: 0.9375rem; color: #A32D2D; margin-bottom: 0.4rem;"><span class="text-xl">⚠</span> App noch nicht installiert</div>
        <div style="font-size: 0.8125rem; color: #501313; line-height: 1.6; margin-bottom: 0.75rem;">Laden Sie die Urban Feed Monitor App herunter:</div>
        <div style="display: flex; gap: 12px; flex-wrap: wrap; align-items: center;">
          <a href="https://apps.apple.com/de/app/urban-feed-monitor/id6746261090" target="_blank" rel="noopener">
            <img src="/appstore-de.svg" alt="Im App Store laden" style="height: 40px; width: auto;" />
          </a>
          <a href="https://play.google.com/store/apps/details?id=com.app.urban_alma_pro" target="_blank" rel="noopener">
            <img src="/playstore-de.svg" alt="Bei Google Play laden" style="height: 40px; width: auto;" />
          </a>
        </div>
      </div>`);
    }

    if (neinAlma) {
      items.push(summaryItem('<span class="text-xl">⚠</span> Kein Alma Pro Fütterungsautomat vorhanden',
        `Die Urban Feed Monitor App setzt einen Alma Pro Fütterungsautomaten voraus. <a href="https://www.urbanonline.de/produkte/detail/urban-alma-pro" target="_blank" rel="noopener">Mehr zur Urban Alma Pro</a> – wenden Sie sich an Ihren Urban-Servicepartner. Das passende TouchTerminal und die aktuelle Firmware sind im Lieferumfang enthalten. Den Urban Router müssen Sie separat bestellen.`));
    }

    if (!neinAlma && neinTerminal) {
      items.push(summaryItem('<span class="text-xl">⚠</span> TouchTerminal Gen 2 fehlt',
        'Wenden Sie sich an Ihren Urban-Servicepartner für einen Austausch.'));
    }

    if (!neinAlma && neinFirmware) {
      let text = 'Vereinbaren Sie einen Servicetermin für das Firmware-Update. Fahren Sie in der Zwischenzeit mit den Schritten 1–3 fort (Registrierung, Einloggen, Stall anlegen), damit beim Servicetermin sofort das Terminal hinzugefügt werden kann. Starten Sie jetzt mit <a href="/guide/user/01-registrierung" style="color: #27500A; font-weight: 600;">Schritt 1: Registrierung</a>.';
      if (neinRouter) text += ' Dieser Termin lässt sich mit der Router-Installation kombinieren.';
      items.push(summaryItem('<span class="text-xl">⚠</span> Firmware veraltet', text));
    }

    if (neinInternet) {
      items.push(summaryItem('<span class="text-xl">⚠</span> Keine Internetverbindung im Stall',
        'Eine Internetverbindung im Stall ist Voraussetzung für die Urban Cloud. Klären Sie dies mit Ihrem Netzwerktechniker – Urban kann hierbei nicht unterstützen.'));
    }

    if (!neinAlma && !neinInternet && neinRouter) {
      let text = 'Wenden Sie sich Ihren Urban-Servicepartner für die Installation des Urban Routers.';
      if (neinFirmware) text += ' Die Installation lässt sich mit dem Firmware-Update kombinieren.';
      items.push(summaryItem('<span class="text-xl">⚠</span> Kein Urban Router vorhanden', text));
    }

    let inner = '';
    if (items.length === 0) {
      inner = `<div style="background: #EAF3DE; border: 1px solid #C0DD97; border-radius: 0.5rem; padding: 1rem 1.25rem; color: #27500A; font-size: 0.875rem; display: flex; align-items: center; gap: 10px;"><span class="text-2xl">✓</span> Alle Voraussetzungen erfüllt. Sie können direkt mit <a href="/guide/user/01-registrierung" style="color: #27500A; font-weight: 600;">Schritt 1: Registrierung</a> starten.</div>`;
    } else {
      const jaCount = Object.values(answers).filter(Boolean).length;
      if (jaCount > 0) inner = `<div style="font-size: 0.875rem; color: #92480A; margin-bottom: 0.75rem; display: flex; align-items: center; gap: 8px;"><span class="text-2xl">⚠</span> ${jaCount} von ${Object.keys(answers).length} Voraussetzungen bereits erfüllt:</div>`;
      inner += items.join('');
    }

    contentEl.innerHTML = `
      <div style="background: ${C.bg}; border: 1px solid ${C.border}; border-radius: 0.75rem; padding: 1.25rem 1.5rem;">
        <div style="font-size: 1.125rem; font-weight: 600; margin-bottom: 1rem; color: ${C.text};">Ergebnis</div>
        ${inner}
        <button id="vw-restart-btn" style="margin-top: 1.25rem; width: 100%; padding: 0.6rem; border-radius: 0.5rem; border: 1px solid ${C.gray4}; background: ${C.bgSidebar}; color: ${C.gray2}; font-size: 0.8125rem; cursor: pointer;">↺ Nochmal von vorne</button>
      </div>`;
    (document.getElementById('vw-restart-btn') as HTMLButtonElement).addEventListener('click', restart);
  }

  function restart(): void {
    current = 0;
    Object.keys(answers).forEach(k => delete answers[k]);
    renderStep();
  }

  renderStep();
})();
</script>
