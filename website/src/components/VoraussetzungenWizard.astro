---
// VoraussetzungenWizard.astro
// Einbindung im MDX:
// import VoraussetzungenWizard from '../../../../components/VoraussetzungenWizard.astro';
// <VoraussetzungenWizard />
---

<div class="vw-wizard" id="vw-wizard">
  <div class="vw-progress" id="vw-progress" aria-hidden="true"></div>
  <div id="vw-content"></div>
</div>

<style>
  .vw-wizard { padding: 1.5rem 0; }
  .vw-progress { display: flex; gap: 6px; margin-bottom: 2rem; }
  .vw-dot { flex: 1; height: 4px; border-radius: 2px; background: var(--sl-color-gray-5); transition: background 0.3s; }
  .vw-dot.done { background: #3B6D11; }
  .vw-dot.active { background: #185FA5; }
  .vw-card { background: var(--sl-color-bg); border: 1px solid var(--sl-color-gray-5); border-radius: 0.75rem; padding: 1.25rem 1.5rem; margin-bottom: 1rem; }
  .vw-step-label { font-size: 0.75rem; color: var(--sl-color-gray-3); margin-bottom: 0.25rem; text-transform: uppercase; letter-spacing: 0.05em; }
  .vw-step-title { font-size: 1.25rem; font-weight: 600; color: var(--sl-color-text); margin-bottom: 0.75rem; border-bottom: 1px solid var(--sl-color-gray-6); padding-bottom: 0.5rem; }
  .vw-step-desc { font-size: 0.9375rem; color: var(--sl-color-text); line-height: 1.6; margin-bottom: 1.25rem; }
  .vw-hint { font-size: 0.8125rem; color: var(--sl-color-gray-2); background: var(--sl-color-bg-sidebar); border-radius: 0.5rem; padding: 0.75rem 1rem; margin-bottom: 1.25rem; line-height: 1.6; }
  .vw-btn-row { display: flex; gap: 10px; }
  .vw-btn { flex: 1; padding: 0.65rem 1rem; border-radius: 0.5rem; border: 1px solid var(--sl-color-gray-4); background: var(--sl-color-bg); color: var(--sl-color-text); font-size: 0.9375rem; cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 8px; transition: background 0.15s; }
  .vw-btn:hover { background: var(--sl-color-bg-sidebar); }
  .vw-btn.ja { border-color: #3B6D11; color: #3B6D11; }
  .vw-btn.ja:hover { background: #EAF3DE; }
  .vw-btn.nein { border-color: #A32D2D; color: #A32D2D; }
  .vw-btn.nein:hover { background: #FCEBEB; }
  .vw-abbruch { background: #FCEBEB; border: 1px solid #F09595; border-radius: 0.75rem; padding: 1.25rem 1.5rem; }
  .vw-abbruch-title { font-size: 1rem; font-weight: 600; color: #A32D2D; margin-bottom: 0.5rem; }
  .vw-abbruch-text { font-size: 0.875rem; color: #501313; line-height: 1.6; margin-bottom: 1rem; }
  .vw-summary { background: var(--sl-color-bg); border: 1px solid var(--sl-color-gray-5); border-radius: 0.75rem; padding: 1.25rem 1.5rem; }
  .vw-sum-title { font-size: 1.125rem; font-weight: 600; margin-bottom: 1rem; color: var(--sl-color-text); }
  .vw-sum-ok { font-size: 0.875rem; color: #3B6D11; margin-bottom: 0.75rem; display: flex; align-items: center; gap: 8px; }
  .vw-sum-item { border-radius: 0.5rem; padding: 0.9rem 1rem; margin-bottom: 0.75rem; border: 1px solid #F09595; border-left: 3px solid #A32D2D; background: #FCEBEB; }
  .vw-sum-item-title { font-weight: 600; font-size: 0.9375rem; color: #A32D2D; margin-bottom: 0.4rem; }
  .vw-sum-item-action { font-size: 0.8125rem; color: #501313; line-height: 1.6; }
  .vw-allgut { background: #EAF3DE; border: 1px solid #C0DD97; border-radius: 0.5rem; padding: 1rem 1.25rem; color: #27500A; font-size: 0.875rem; display: flex; align-items: center; gap: 10px; }
  .vw-restart { margin-top: 1.25rem; width: 100%; padding: 0.6rem; border-radius: 0.5rem; border: 1px solid var(--sl-color-gray-4); background: var(--sl-color-bg-sidebar); color: var(--sl-color-gray-2); font-size: 0.8125rem; cursor: pointer; }
  .vw-restart:hover { background: var(--sl-color-bg); }
</style>

<script>
(function () {
  interface Abbruch {
    title: string;
    text: string;
  }

  interface NeinAction {
    title: string;
    action: string;
  }

  interface Step {
    id: string;
    label: string;
    title: string;
    question: string;
    hint: string | null;
    abbruch: Abbruch | null;
    nein: NeinAction | null;
  }

  const steps: Step[] = [
    {
      id: 'smartphone',
      label: 'Checkpoint 1',
      title: 'Smartphone',
      question: 'Ist ein iPhone oder Android-Gerät vorhanden?',
      hint: null,
      abbruch: {
        title: 'Kein Smartphone vorhanden',
        text: 'Die Urban Feed Monitor App erfordert ein iPhone (iOS) oder ein Android-Gerät.',
      },
      nein: null,
    },
    {
  id: 'appstore',
  label: 'Checkpoint 2',
  title: 'App installiert',
  question: 'Ist die Urban Feed Monitor App bereits auf Ihrem Gerät installiert?',
  hint: null,
  abbruch: null,
  nein: {
    title: 'App noch nicht installiert',
    action: 'Laden Sie die Urban Feed Monitor App herunter: <a href="https://apps.apple.com/de/app/urban-feed-monitor/id6746261090">App Store (iOS)</a> oder <a href="https://play.google.com/store/apps/details?id=com.app.urban_alma_pro">Google Play (Android)</a>',
  },
},
    {
      id: 'alma',
      label: 'Checkpoint 3',
      title: 'Automat',
      question: 'Ist ein Fütterungsautomat Alma Pro vorhanden?',
      hint: null,
      abbruch: {
        title: 'Kein Alma Pro vorhanden',
        text: 'Die Urban Feed Monitor App setzt eine Alma Pro voraus, wenden Sie sich an Urban oder Ihren Vertriebspartner. Mit der Lieferung einer neuen Alma Pro erhalten Sie automatisch das passende TouchTerminal und die aktuelle Firmware.',
      },
      nein: null,
    },
    {
      id: 'terminal',
      label: 'Checkpoint 4',
      title: 'TouchTerminal',
      question: 'Ist ein TouchTerminal der 2. Generation vorhanden?',
      hint: 'Terminals der 2. Generation wurden ab 2020 ausgeliefert.',
      abbruch: null,
      nein: {
        title: 'TouchTerminal Gen 2 fehlt',
        action: 'Wenden Sie sich an Urban oder Ihren Vertriebspartner für einen Austausch.',
      },
    },
    {
      id: 'firmware',
      label: 'Checkpoint 5',
      title: 'Firmware',
      question: 'Ist Firmwareversion 25-04-V08 oder höher auf dem Alma Pro installiert?',
      hint: 'Prüfung am Gerät: Home-Schaltfläche → Hilfe-Symbol (oben rechts). Die Versionsnummer erscheint links neben der Sprachumschaltung. <a href="/prerequisites/feeder/firmware">Detaillierte Anleitung</a>',
      abbruch: null,
      nein: {
        title: 'Firmware veraltet',
        action: 'Vereinbaren Sie einen Servicetermin für das Firmware-Update. Fahren Sie in der Zwischenzeit mit den Schritten 1–3 fort (Registrierung, Einloggen, Stall anlegen), damit beim Servicetermin nur noch das Terminal hinzugefügt werden muss.',
      },
    },
    {
      id: 'internet',
      label: 'Checkpoint 6',
      title: 'Internetverbindung im Stall',
      question: 'Ist im Stall eine Internetverbindung vorhanden?',
      hint: null,
      abbruch: {
        title: 'Keine Internetverbindung im Stall',
        text: 'Eine Internetverbindung im Stall ist Voraussetzung für die Urban Cloud. Klären Sie dies mit Ihrem Internetanbieter, Urban kann hierbei nicht unterstützen.',
      },
      nein: null,
    },
    {
      id: 'router',
      label: 'Checkpoint 7',
      title: 'Urban Router',
      question: 'Ist ein Urban Router im Stall installiert?',
      hint: null,
      abbruch: null,
      nein: {
        title: 'Kein Urban Router vorhanden',
        action: 'Wenden Sie sich an Urban oder Ihren Vertriebspartner für die Installation des Urban Routers.',
      },
    },
  ];

  const total = steps.length;
  let current = 0;
  const answers: Record<string, boolean> = {};

  const progressEl = document.getElementById('vw-progress') as HTMLElement;
  const contentEl = document.getElementById('vw-content') as HTMLElement;

  function renderProgress(activeIdx: number, allDone: boolean): void {
    progressEl.innerHTML = Array.from({ length: total }, (_, i) => {
      let cls = 'vw-dot';
      if (allDone || i < activeIdx) cls += ' done';
      else if (i === activeIdx) cls += ' active';
      return `<div class="${cls}"></div>`;
    }).join('');
  }

  function renderStep(): void {
    const s = steps[current];
    renderProgress(current, false);
    const hintHtml = s.hint ? `<div class="vw-hint">${s.hint}</div>` : '';
    contentEl.innerHTML = `
      <div class="vw-card">
        <div class="vw-step-label">${s.label} von ${total}</div>
        <div class="vw-step-title">${s.title}</div>
        <div class="vw-step-desc">${s.question}</div>
        ${hintHtml}
        <div class="vw-btn-row">
          <button class="vw-btn nein" data-answer="false">✕ Nein</button>
          <button class="vw-btn ja" data-answer="true">✓ Ja</button>
        </div>
      </div>`;
    contentEl.querySelectorAll('.vw-btn').forEach((btn) => {
      const el = btn as HTMLButtonElement;
      el.addEventListener('click', () => answer(el.dataset['answer'] === 'true'));
    });
  }

  function answer(ja: boolean): void {
    const s = steps[current];
    answers[s.id] = ja;
    if (!ja && s.abbruch) { renderAbbruch(s.abbruch); return; }
    current++;
    if (current < total) { renderStep(); } else { renderSummary(); }
  }

  function renderAbbruch(abbruch: Abbruch): void {
    renderProgress(current, false);
    contentEl.innerHTML = `
      <div class="vw-abbruch">
        <div class="vw-abbruch-title">⚠ ${abbruch.title}</div>
        <div class="vw-abbruch-text">${abbruch.text}</div>
        <button class="vw-restart">↺ Nochmal von vorne</button>
      </div>`;
    (contentEl.querySelector('.vw-restart') as HTMLButtonElement).addEventListener('click', restart);
  }

function renderSummary(): void {
  renderProgress(0, true);

  const neinAppstore = answers['appstore'] === false;
  const neinTerminal = answers['terminal'] === false;
  const neinFirmware = answers['firmware'] === false;
  const neinRouter   = answers['router']   === false;

  const items: string[] = [];

  if (neinAppstore) {
    items.push(`<div style="border: 1px solid #F09595; border-left: 3px solid #A32D2D; background: #FCEBEB; border-radius: 0.5rem; padding: 0.9rem 1rem; margin-bottom: 0.75rem;">
      <div style="font-weight: 700; font-size: 0.9375rem; color: #A32D2D; margin-bottom: 0.4rem;">↓ App noch nicht installiert</div>
      <div style="font-size: 0.8125rem; color: #501313; line-height: 1.6; margin-bottom: 0.75rem;">Laden Sie die Urban Feed Monitor App herunter:</div>
      <div style="display: flex; gap: 12px; flex-wrap: wrap; align-items: center;">
        <a href="https://apps.apple.com/de/app/urban-feed-monitor/id6746261090" target="_blank" rel="noopener">
          <img src="/appstore-de.svg" alt="Im App Store laden" style="height: 40px; width: auto;" />
        </a>
        <a href="https://play.google.com/store/apps/details?id=com.app.urban_alma_pro" target="_blank" rel="noopener">
          <img src="/playstore-de.svg" alt="Bei Google Play laden" style="height: 40px; width: auto;" />
        </a>
      </div>
    </div>`);
  }

  if (neinTerminal) {
    items.push(`<div style="border: 1px solid #F09595; border-left: 3px solid #A32D2D; background: #FCEBEB; border-radius: 0.5rem; padding: 0.9rem 1rem; margin-bottom: 0.75rem;">
      <div style="font-weight: 700; font-size: 0.9375rem; color: #A32D2D; margin-bottom: 0.4rem;">⚠ TouchTerminal Gen 2 fehlt</div>
      <div style="font-size: 0.8125rem; color: #501313; line-height: 1.6;">Wenden Sie sich an Urban oder Ihren Vertriebspartner für einen Austausch.</div>
    </div>`);
  }

  if (neinFirmware) {
    let text = 'Vereinbaren Sie einen Servicetermin für das Firmware-Update. Fahren Sie in der Zwischenzeit mit den Schritten 1–3 fort (Registrierung, Einloggen, Stall anlegen), damit beim Servicetermin nur noch das Terminal hinzugefügt werden muss.';
    if (neinRouter) text += ' Dieser Termin lässt sich mit der Router-Installation kombinieren.';
    items.push(`<div style="border: 1px solid #F09595; border-left: 3px solid #A32D2D; background: #FCEBEB; border-radius: 0.5rem; padding: 0.9rem 1rem; margin-bottom: 0.75rem;">
      <div style="font-weight: 700; font-size: 0.9375rem; color: #A32D2D; margin-bottom: 0.4rem;">⚠ Firmware veraltet</div>
      <div style="font-size: 0.8125rem; color: #501313; line-height: 1.6;">${text}</div>
    </div>`);
  }

  if (neinRouter) {
    let text = 'Wenden Sie sich an Urban oder Ihren Vertriebspartner für die Installation des Urban Routers.';
    if (neinFirmware) text += ' Die Installation lässt sich mit dem Firmware-Update kombinieren.';
    items.push(`<div style="border: 1px solid #F09595; border-left: 3px solid #A32D2D; background: #FCEBEB; border-radius: 0.5rem; padding: 0.9rem 1rem; margin-bottom: 0.75rem;">
      <div style="font-weight: 700; font-size: 0.9375rem; color: #A32D2D; margin-bottom: 0.4rem;">⚠ Kein Urban Router vorhanden</div>
      <div style="font-size: 0.8125rem; color: #501313; line-height: 1.6;">${text}</div>
    </div>`);
  }

  let inner = '';
  if (items.length === 0) {
    inner = `<div style="background: #EAF3DE; border: 1px solid #C0DD97; border-radius: 0.5rem; padding: 1rem 1.25rem; color: #27500A; font-size: 0.875rem; display: flex; align-items: center; gap: 10px;">✓ Alle Voraussetzungen erfüllt. Sie können direkt mit Schritt 1 starten.</div>`;
  } else {
    const jaCount = Object.values(answers).filter(Boolean).length;
    if (jaCount > 0) inner = `<div style="font-size: 0.875rem; color: #3B6D11; margin-bottom: 0.75rem; display: flex; align-items: center; gap: 8px;">✓ ${jaCount} von ${total} Voraussetzungen bereits erfüllt.</div>`;
    inner += items.join('');
  }

  contentEl.innerHTML = `
    <div style="background: var(--sl-color-bg); border: 1px solid var(--sl-color-gray-5); border-radius: 0.75rem; padding: 1.25rem 1.5rem;">
      <div style="font-size: 1.125rem; font-weight: 600; margin-bottom: 1rem; color: var(--sl-color-text);">Ergebnis</div>
      ${inner}
      <button class="vw-restart">↺ Nochmal von vorne</button>
    </div>`;
  (contentEl.querySelector('.vw-restart') as HTMLButtonElement).addEventListener('click', restart);
}

  function restart(): void {
    current = 0;
    Object.keys(answers).forEach(k => delete answers[k]);
    renderStep();
  }

  renderStep();
})();
</script>
